#!/bin/bash
# Show NanoClaw status — instances, containers, versions, health
#
# Usage:
#   ./scripts/status

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "=== Instances ==="
echo ""

# Staging
STAGE_PID=$(pgrep -f "NANOCLAW_INSTANCE=staging" 2>/dev/null | head -1)
STAGE_BUILD=$(cat "$PROJECT_ROOT/builds/staging/build-id.txt" 2>/dev/null || echo "none")
if [ -n "$STAGE_PID" ]; then
  echo "  Staging:  RUNNING (pid $STAGE_PID, build $STAGE_BUILD)"
else
  echo "  Staging:  STOPPED (build $STAGE_BUILD)"
fi

# Live
LIVE_PID=$(pgrep -f "NANOCLAW_INSTANCE=live" 2>/dev/null | head -1)
LIVE_BUILD=$(cat "$PROJECT_ROOT/builds/live/build-id.txt" 2>/dev/null || echo "none")
LIVE_TARGET=$(readlink "$PROJECT_ROOT/builds/live" 2>/dev/null || echo "none")
if [ -n "$LIVE_PID" ]; then
  echo "  Live:     RUNNING (pid $LIVE_PID, build $LIVE_BUILD)"
else
  echo "  Live:     STOPPED (build $LIVE_BUILD)"
fi

echo ""
echo "=== Containers ==="
docker ps --filter name=nanoclaw --format '  {{.Names}}  {{.Status}}' 2>/dev/null || echo "  Docker not available"

echo ""
echo "=== Builds ==="
echo "  Staging: $STAGE_BUILD"
echo "  Live:    $LIVE_BUILD → $(basename "$LIVE_TARGET" 2>/dev/null || echo "?")"
echo ""
echo "=== Services ==="
curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1 && echo "  Ollama:          UP" || echo "  Ollama:          DOWN"
curl -sf http://127.0.0.1:8888/healthz >/dev/null 2>&1 && echo "  SearXNG:         UP" || echo "  SearXNG:         DOWN"
curl -sf http://127.0.0.1:8000/system_stats >/dev/null 2>&1 && echo "  ComfyUI:         UP" || echo "  ComfyUI:         DOWN"
curl -sf http://127.0.0.1:8001/api/models >/dev/null 2>&1 && echo "  OllamaDiffuser:  UP" || echo "  OllamaDiffuser:  DOWN"
